# ========================================
# REQUIRED CONFIGURATION
# ========================================

# Your Immich server URL (no trailing slash)
# Examples:
#   - Local: http://localhost:2283
#   - Network: http://192.168.1.100:2283
#   - Docker: http://immich-server:2283
IMMICH_URL=http://localhost:2283

# Your Immich API key
# Get this from Immich: User Settings → Account Settings → API Keys
IMMICH_API_KEY=your-immich-api-key-here


# ========================================
# OPTIONAL SERVER CONFIGURATION
# ========================================

# Port the server will run on (default: 3000)
PORT=3000


# ========================================
# OPTIONAL FRONTEND DEFAULTS
# ========================================
# These set initial values when users first load the app
# Users can change these settings in the UI
# Changed settings are stored in browser localStorage

# Layout: single or split
VITE_DEFAULT_LAYOUT=single

# Slideshow interval in milliseconds
VITE_DEFAULT_INTERVAL_MS=5000

# Shuffle photos: true or false
VITE_DEFAULT_SHUFFLE=true

# Auto-start slideshow: true or false
VITE_DEFAULT_AUTOPLAY=true

# Image fit: contain, cover, fill, none, or scale-down
VITE_DEFAULT_OBJECT_FIT=contain

# Theme: light, dark, or system
VITE_DEFAULT_THEME=system

# Show clock overlay: true or false
VITE_DEFAULT_SHOW_CLOCK=true

# Show weather overlay: true or false (requires VITE_OWM_KEY)
VITE_DEFAULT_SHOW_WEATHER=false

# Show progress bar: true or false
VITE_DEFAULT_SHOW_PROGRESS_BAR=true

# Show photo metadata: true or false
VITE_DEFAULT_SHOW_PHOTO_METADATA=true

# Font size: sm, base, lg, or xl
VITE_DEFAULT_FONT_SIZE=base

# Use 24-hour time format: true or false
VITE_DEFAULT_24_HOUR_FORMAT=false

# Transition type: fade, slide, or none
VITE_DEFAULT_TRANSITION_TYPE=fade

# Transition duration in milliseconds
VITE_DEFAULT_TRANSITION_DURATION=500


# ========================================
# OPTIONAL PHOTO FILTERS
# ========================================

# Filter by album IDs (comma-separated, no spaces)
# Example: VITE_DEFAULT_ALBUM_IDS=abc123,def456,ghi789
# Leave empty to show all albums
VITE_DEFAULT_ALBUM_IDS=

# Filter by person IDs (comma-separated, no spaces)
# Example: VITE_DEFAULT_PERSON_IDS=person1,person2
# Leave empty to show all people
VITE_DEFAULT_PERSON_IDS=

# Filter by location
# Leave empty to show all locations
VITE_DEFAULT_LOCATION_COUNTRY=
VITE_DEFAULT_LOCATION_STATE=
VITE_DEFAULT_LOCATION_CITY=


# ========================================
# OPTIONAL WEATHER INTEGRATION
# ========================================

# OpenWeatherMap API key (required for weather feature)
# Get free API key at: https://openweathermap.org/api
VITE_OWM_KEY=

# Default weather location coordinates
# Example: San Francisco
#   VITE_DEFAULT_WEATHER_LAT=37.7749
#   VITE_DEFAULT_WEATHER_LNG=-122.4194
VITE_DEFAULT_WEATHER_LAT=
VITE_DEFAULT_WEATHER_LNG=
