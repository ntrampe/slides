# Immich
IMMICH_URL=your_immich_url
IMMICH_API_KEY=your_immich_key

# Mock Mode
VITE_USE_MOCK=false

# Weather API
VITE_OWM_KEY=your_openweathermap_key

# Slideshow Defaults
VITE_DEFAULT_LAYOUT=single
VITE_DEFAULT_INTERVAL_MS=5000
VITE_DEFAULT_SHUFFLE=true
VITE_DEFAULT_AUTOPLAY=true
VITE_DEFAULT_OBJECT_FIT=cover

# UI Defaults
VITE_DEFAULT_THEME=dark
VITE_DEFAULT_SHOW_CLOCK=true
VITE_DEFAULT_SHOW_WEATHER=false
VITE_DEFAULT_SHOW_PROGRESS_BAR=true
VITE_DEFAULT_SHOW_PHOTO_METADATA=true
VITE_DEFAULT_FONT_SIZE=base

# Clock/Time Defaults
VITE_DEFAULT_24_HOUR_FORMAT=false

# Weather Location (London by default)
VITE_DEFAULT_WEATHER_LAT=51.5074
VITE_DEFAULT_WEATHER_LNG=-0.1278

# Filter Defaults (comma-separated IDs)
VITE_DEFAULT_ALBUM_IDS=album-uuid-1,album-uuid-2
VITE_DEFAULT_PERSON_IDS=person-uuid-1,person-uuid-2

# Local Server Settings
PORT=3000